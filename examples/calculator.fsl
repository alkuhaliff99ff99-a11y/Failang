دالة جمع أ ب
    ارجع أ + ب

دالة طرح أ ب
    ارجع أ - ب

دالة ضرب أ ب
    ارجع أ * ب

دالة قسمة أ ب
    ارجع أ / ب

متغير س = 15
متغير ص = 5

اطبع "--- حاسبة Failang الميسرة ---"

اطبع "تجربة مقارنة النص مباشرة:"
متغير رمز = "+"
إذا رمز يساوي "+"
    اطبع "نجحت مقارنة النصوص باللغة العربية!"

اطبع "الجمع:"
متغير ن_جمع = جمع س ص
اطبع ن_جمع

اطبع "الطرح:"
متغير ن_طرح = طرح س ص
اطبع ن_طرح

اطبع "الضرب:"
متغير ن_ضرب = ضرب س ص
اطبع ن_ضرب

اطبع "القسمة:"
متغير ن_قسمة = قسمة س ص
اطبع ن_قسمة
